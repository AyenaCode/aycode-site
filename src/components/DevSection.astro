---
const features = [
  {
    icon: '⚡',
    title: 'Livraison rapide',
    desc: 'MVP en 4 semaines. Itérations courtes, feedback continu, time-to-market optimisé.',
  },
  {
    icon: '🏗️',
    title: 'Code qui dure',
    desc: 'Architecture scalable, tests, documentation. Votre codebase reste maintenable après la mission.',
  },
  {
    icon: '✨',
    title: 'UX qui convertit',
    desc: 'Interfaces fluides, accessibles et performantes. Vos utilisateurs reviennent.',
  },
];
---

<section id="dev" class="section-padding px-6">
  <div class="max-w-6xl mx-auto grid lg:grid-cols-2 gap-16 items-center">

    <div>
      <p class="text-sm font-medium uppercase tracking-widest mb-4 gsap-reveal" style="color:#06b6d4;">Ce qu'on livre</p>
      <h2 class="font-display font-bold text-white mb-6 gsap-reveal leading-tight" style="font-size:clamp(1.8rem,4vw,3.2rem);">
        Web & mobile —<br />
        <span class="gradient-text">du brief à la mise en ligne.</span>
      </h2>
      <p class="text-lg mb-10 gsap-reveal leading-relaxed" style="color:#94a3b8;">
        Applications mobiles iOS & Android, web, MVPs. Une équipe dédiée à votre projet, un interlocuteur unique pour vous.
      </p>
      <a href="#contact" class="gsap-reveal inline-flex items-center gap-2 font-semibold transition-all duration-200 hover:gap-4" style="color:#06b6d4;">
        Parlons de votre projet
        <svg width="20" height="20" viewBox="0 0 20 20" fill="none">
          <path d="M4 10h12M12 6l4 4-4 4" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </a>
    </div>

    <div class="flex flex-col gap-4">
      {features.map((f) => (
        <div class="dev-feature card-glass rounded-2xl p-6 flex gap-5 items-start gsap-reveal transition-all duration-300 hover:border-cyan-500/40">
          <div class="text-3xl shrink-0 animate-float">{f.icon}</div>
          <div>
            <h3 class="font-display font-semibold text-white mb-1">{f.title}</h3>
            <p class="text-sm leading-relaxed" style="color:#94a3b8;">{f.desc}</p>
          </div>
        </div>
      ))}
    </div>

  </div>
</section>

<script>
  import gsap from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';
  gsap.registerPlugin(ScrollTrigger);

  gsap.to('#dev .gsap-reveal', {
    opacity: 1, y: 0, duration: 0.7, stagger: 0.12, ease: 'power3.out',
    scrollTrigger: { trigger: '#dev', start: 'top 75%' },
  });
</script>
