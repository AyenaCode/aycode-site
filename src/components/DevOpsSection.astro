---
const features = [
  {
    icon: '🔄',
    title: 'Pipelines CI/CD robustes',
    desc: 'GitHub Actions, GitLab CI. Tests automatisés, déploiements zéro-downtime. Chaque commit livré en confiance.',
  },
  {
    icon: '☸️',
    title: 'Infra Kubernetes haute dispo',
    desc: 'Clusters K8s scalables, autoscaling, health checks. Votre infra tient la charge, même en pic.',
  },
  {
    icon: '📊',
    title: 'Monitoring & alerting',
    desc: 'Prometheus, Grafana, alertes proactives. Vous dormez tranquille, je surveille.',
  },
];
---

<section id="devops" class="section-padding px-6" style="position:relative;">

  <div class="absolute inset-0 pointer-events-none overflow-hidden" style="z-index:0;">
    <div class="absolute top-1/2 -translate-y-1/2 -left-40 w-96 h-96 rounded-full blur-3xl" style="background:rgba(124,58,237,0.1);"></div>
    <div class="absolute top-1/2 -translate-y-1/2 -right-40 w-80 h-80 rounded-full blur-3xl" style="background:rgba(236,72,153,0.07);"></div>
  </div>

  <div class="max-w-6xl mx-auto grid lg:grid-cols-2 gap-16 items-center relative" style="z-index:1;">

    <div class="flex flex-col gap-4 order-2 lg:order-1">
      {features.map((f) => (
        <div class="devops-feature card-glass rounded-2xl p-6 flex gap-5 items-start gsap-reveal transition-all duration-300 hover:border-violet-600/40">
          <div class="text-3xl shrink-0 animate-float">{f.icon}</div>
          <div>
            <h3 class="font-display font-semibold text-white mb-1">{f.title}</h3>
            <p class="text-sm leading-relaxed" style="color:#94a3b8;">{f.desc}</p>
          </div>
        </div>
      ))}
    </div>

    <div class="order-1 lg:order-2">
      <p class="text-sm font-medium uppercase tracking-widest mb-4 gsap-reveal" style="color:#7c3aed;">Services DevOps</p>
      <h2 class="font-display font-bold text-white mb-6 gsap-reveal leading-tight" style="font-size:clamp(1.8rem,4vw,3.2rem);">
        Vos déploiements,<br />
        <span class="gradient-text">automatisés et blindés.</span>
      </h2>
      <p class="text-lg mb-10 gsap-reveal leading-relaxed" style="color:#94a3b8;">
        Stop aux déploiements manuels stressants. Je mets en place l'infrastructure
        qui vous permet de livrer vite, souvent, et sans peur.
      </p>
      <a href="#contact" class="gsap-reveal inline-flex items-center gap-2 font-semibold transition-all duration-200 hover:gap-4" style="color:#7c3aed;">
        Automatiser mon infra
        <svg width="20" height="20" viewBox="0 0 20 20" fill="none">
          <path d="M4 10h12M12 6l4 4-4 4" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </a>
    </div>

  </div>
</section>

<script>
  import gsap from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';
  gsap.registerPlugin(ScrollTrigger);

  gsap.to('#devops .gsap-reveal', {
    opacity: 1, y: 0, duration: 0.7, stagger: 0.12, ease: 'power3.out',
    scrollTrigger: { trigger: '#devops', start: 'top 75%' },
  });
</script>
